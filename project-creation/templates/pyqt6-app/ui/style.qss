/* {{PROJECT_NAME}} - Global Stylesheet */

QMainWindow, QWidget {
    background-color: #1e1e2e;
    color: #cdd6f4;
    font-family: "Segoe UI", "Inter", sans-serif;
    font-size: 13px;
}

QTabWidget::pane {
    border: 1px solid #313244;
    border-radius: 4px;
}

QTabBar::tab {
    background: #181825;
    color: #a6adc8;
    padding: 8px 20px;
    border: none;
}

QTabBar::tab:selected {
    background: #313244;
    color: #cdd6f4;
    border-bottom: 2px solid #89b4fa;
}

QPushButton {
    background-color: #89b4fa;
    color: #1e1e2e;
    border: none;
    border-radius: 4px;
    padding: 6px 16px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #b4befe;
}

QPushButton:pressed {
    background-color: #74c7ec;
}

QLineEdit, QTextEdit, QComboBox {
    background-color: #313244;
    border: 1px solid #45475a;
    border-radius: 4px;
    padding: 5px 8px;
    color: #cdd6f4;
}

QStatusBar {
    background: #181825;
    color: #6c7086;
    font-size: 11px;
}
